# ─── Google Maps ─────────────────────────────────────────────────────────────
# Ottieni le chiavi su: https://console.cloud.google.com/apis/credentials

# Web / Electron  → abilita: Maps JavaScript API
EXPO_PUBLIC_GOOGLE_MAPS_KEY=inserisci_la_tua_chiave_web_qui

# iOS  → abilita: Maps SDK for iOS
EXPO_PUBLIC_GOOGLE_MAPS_IOS_KEY=inserisci_la_tua_chiave_ios_qui

# Android  → abilita: Maps SDK for Android
EXPO_PUBLIC_GOOGLE_MAPS_ANDROID_KEY=inserisci_la_tua_chiave_android_qui

# ─── Firebase / Google Sign-In ───────────────────────────────────────────────
# Scarica GoogleService-Info.plist da Firebase Console → Project settings → iOS app
# e mettilo nella root del progetto (mai dentro ios/ che viene rigenerata).
#
# REVERSED_CLIENT_ID: valore del campo REVERSED_CLIENT_ID nel plist
REVERSED_CLIENT_ID=com.googleusercontent.apps.INSERISCI_QUI
#
# GOOGLE_WEB_CLIENT_ID: client ID del tipo "Web application" in Google Cloud Console
# (serve per Google Sign-In con Firebase Auth)
GOOGLE_WEB_CLIENT_ID=INSERISCI_QUI.apps.googleusercontent.com
