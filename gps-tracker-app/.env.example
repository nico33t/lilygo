# ─── Google Maps ─────────────────────────────────────────────────────────────
# Ottieni le chiavi su: https://console.cloud.google.com/apis/credentials

# Web / Electron  → abilita: Maps JavaScript API
EXPO_PUBLIC_GOOGLE_MAPS_KEY=inserisci_la_tua_chiave_web_qui

# iOS  → abilita: Maps SDK for iOS
EXPO_PUBLIC_GOOGLE_MAPS_IOS_KEY=inserisci_la_tua_chiave_ios_qui

# Android  → abilita: Maps SDK for Android
EXPO_PUBLIC_GOOGLE_MAPS_ANDROID_KEY=inserisci_la_tua_chiave_android_qui
