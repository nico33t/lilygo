{
  "appId": "com.lilygo.gpstracker",
  "productName": "GPS Tracker",
  "extraMetadata": {
    "main": "electron/main.js"
  },
  "files": [
    "dist/**",
    "electron/**",
    "package.json"
  ],
  "directories": {
    "output": "release"
  },
  "mac": {
    "target": [{ "target": "dmg", "arch": ["x64", "arm64"] }],
