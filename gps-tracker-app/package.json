{
  "name": "gps-tracker-app",
  "version": "0.0.2",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "build:web": "expo export --platform web",
    "postinstall": "node scripts/copy-leaflet.js",
    "electron:dev": "concurrently \"expo start --web\" \"wait-on http://localhost:8081 && electron electron/main.js\"",
    "electron:build": "npm run build:web && electron-builder --config electron-builder.json"
  },
  "dependencies": {
    "@expo/vector-icons": "^14.0.0",
    "@react-native-community/slider": "^4.5.5",
    "expo": "~52.0.0",
    "expo-router": "~4.0.7",
    "expo-status-bar": "~2.0.0",
    "leaflet": "^1.9.4",
    "react": "18.3.2",
    "react-dom": "18.3.2",
    "react-native": "0.76.9",
    "react-native-maps": "^1.18.0",
    "react-native-web": "~0.19.13",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@types/leaflet": "^1.9.0",
    "@types/react": "~18.3.0",
    "@types/react-native": "~0.76.0",
    "concurrently": "^9.0.0",
    "electron": "^32.0.0",
    "electron-builder": "^25.0.0",
    "typescript": "^5.3.0",
    "wait-on": "^8.0.0"
  }
}
