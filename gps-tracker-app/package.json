{
  "name": "gps-tracker-app",
  "version": "0.0.2",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "build:web": "expo export --platform web",
    "electron:dev": "concurrently \"expo start --web\" \"wait-on http://localhost:8081 && electron electron/main.js\"",
    "electron:build": "npm run build:web && electron-builder --config electron-builder.json"
  },
  "dependencies": {
    "@expo/vector-icons": "^14.0.0",
    "@googlemaps/js-api-loader": "^1.16.8",
    "@react-native-async-storage/async-storage": "1.23.1",
    "@react-native-community/slider": "^4.5.5",
    "expo": "~52.0.0",
    "expo-asset": "~11.0.5",
    "expo-constants": "~17.0.8",
    "expo-linking": "~7.0.5",
    "expo-network": "~7.0.5",
    "expo-router": "~4.0.7",
    "expo-status-bar": "~2.0.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-native": "0.76.7",
    "react-native-maps": "^1.18.0",
    "react-native-safe-area-context": "4.12.0",
    "react-native-screens": "~4.4.0",
    "react-native-web": "~0.19.13",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@types/google.maps": "^3.58.0",
    "@types/react": "~18.3.0",
    "concurrently": "^9.0.0",
    "electron": "^32.0.0",
    "electron-builder": "^25.0.0",
    "typescript": "^5.3.0",
    "wait-on": "^8.0.0"
  }
}
